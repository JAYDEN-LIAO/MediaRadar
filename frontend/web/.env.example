# ===== MediaRadar Web 环境变量示例 =====
# 复制为 .env.local 并填写真实值

# ---- Mock 模式 ----
# 设为 "true" 时启用 MSW mock，无需后端即可运行前端
NEXT_PUBLIC_USE_MOCK=true

# ---- 后端 API ----
# Next.js 客户端请求会代理到该地址
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8008

# ---- next-auth ----
# 生成方式: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-strong-random-secret-32bytes-min
NEXTAUTH_URL=http://127.0.0.1:3000

# ---- OAuth Providers（占位）----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 微信开放平台（占位）
WECHAT_CLIENT_ID=your-wechat-app-id
WECHAT_CLIENT_SECRET=your-wechat-app-secret

# ---- 邮箱白名单（逗号分隔，留空则放行所有）----
AUTH_ALLOWED_EMAILS=
