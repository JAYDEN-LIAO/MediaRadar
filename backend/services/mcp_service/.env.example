# MediaRadar MCP Server 环境变量
# 复制此文件为 .env 并填入实际值

# ======== Screener & Analyst (DeepSeek) ========
ANALYST_BASE_URL="https://api.deepseek.com/v1"
ANALYST_API_KEY="your-deepseek-api-key"
ANALYST_MODEL="deepseek-chat"

# ======== Reviewer & Director (Kimi/Moonshot) ========
REVIEWER_BASE_URL="https://api.moonshot.cn/v1"
REVIEWER_API_KEY="your-kimi-api-key"
REVIEWER_MODEL="moonshot-v1-8k"

# ======== Embedding (硅基流动) ========
EMBEDDING_BASE_URL="https://api.siliconflow.cn/v1"
EMBEDDING_API_KEY="your-siliconflow-api-key"
EMBEDDING_MODEL="BAAI/bge-m3"

# ======== Vision (Qwen-VL) ========
VISION_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
VISION_API_KEY="your-aliyun-api-key"
VISION_MODEL="qwen-vl-max"

# ======== MCP Server ========
MCP_TRANSPORT="stdio"
MCP_HOST="127.0.0.1"
MCP_PORT="8001"
