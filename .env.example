# ======== 默认模型（所有 Agent 的兜底配置）=======
DEFAULT_BASE_URL="https://api.deepseek.com/v1"
DEFAULT_API_KEY=""
DEFAULT_MODEL="deepseek-chat"

# ======== 分析员（舆情风险分析）=======
ANALYST_BASE_URL=""
ANALYST_API_KEY=""
ANALYST_MODEL=""

# ======== 复核员（交叉复核判定）=======
REVIEWER_BASE_URL=""
REVIEWER_API_KEY=""
REVIEWER_MODEL=""

# ======== 向量引擎（文本向量聚类）=======
EMBEDDING_BASE_URL=""
EMBEDDING_API_KEY=""
EMBEDDING_MODEL=""

# ======== 视觉引擎（图片证据解析）=======
VISION_BASE_URL=""
VISION_API_KEY=""
VISION_MODEL=""

# ======== Qdrant 向量数据库 ========
QDRANT_HOST="127.0.0.1"
QDRANT_PORT="6333"
QDRANT_COLLECTION="yq_history"
TOPIC_COLLECTION="topic_evolution"

# ======== API Gateway ========
API_KEYS="mr-your-api-key-here"

# ======== 日志配置（可选）=======
LOG_LEVEL="INFO"
LOG_FORMAT="text"
LOG_TO_FILE="true"
LOG_TO_CONSOLE="true"