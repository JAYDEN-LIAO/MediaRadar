# MediaRadar 生产环境配置示例
# 复制为 .env 并填入真实值：cp .env.production.example .env
# 部署域名：mediaradar.jaydennn.xyz（已 ICP 备案）
# 服务器 IP：124.220.10.233

# =====================================================
# 基础服务
# =====================================================
ENV=prod
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_USE_UTC=true

# =====================================================
# 部署域名 / 跨域
# =====================================================
# 逗号分隔的允许来源（生产环境必须精确控制）
ALLOWED_ORIGINS=https://mediaradar.jaydennn.xyz,https://www.mediaradar.jaydennn.xyz

# =====================================================
# API 密钥（后端鉴权 + 前端调用）
# =====================================================
# 旧式 API_KEY 鉴权（与 JWT 并存一段时间）
API_KEYS=CHANGE_ME_LONG_RANDOM_STRING
DEFAULT_API_KEY=CHANGE_ME_DEFAULT_API_KEY

# =====================================================
# WS4: JWT 配置
# =====================================================
# 必须 >= 32 字节随机串（建议 openssl rand -base64 48）
JWT_SECRET=CHANGE_ME_TO_48_BYTES_RANDOM_BASE64_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# =====================================================
# WS4: OAuth 第三方登录
# =====================================================
# 回调基础地址（前端后端共用）
OAUTH_REDIRECT_BASE=https://mediaradar.jaydennn.xyz

# Google OAuth（推荐优先接入，30 分钟可完成注册）
# 申请地址：https://console.cloud.google.com/apis/credentials
# Authorized redirect URI 必须填：https://mediaradar.jaydennn.xyz/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 微信扫码登录（v2.1 接入，需个人开发者资质）
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# =====================================================
# LLM 模型配置（5 个 Agent 角色）
# =====================================================
# 默认模型（所有 Agent 的兜底配置）
DEFAULT_BASE_URL=https://api.deepseek.com/v1
DEFAULT_MODEL=deepseek-chat
DEFAULT_API_KEY=sk-your-deepseek-key

# 分析员 / 复核员（不配则回退到 DEFAULT）
# ANALYST_BASE_URL=
# ANALYST_MODEL=
# ANALYST_API_KEY=
# REVIEWER_BASE_URL=
# REVIEWER_MODEL=
# REVIEWER_API_KEY=

# 向量引擎（聚类）
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=sk-your-siliconflow-key

# 视觉引擎（图片证据）
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-max
VISION_API_KEY=sk-your-dashscope-key

# Agent 智能体（不配则回退到 ANALYST → DEFAULT）
# AGENT_BASE_URL=
# AGENT_MODEL=
# AGENT_API_KEY=

# =====================================================
# Qdrant 向量库
# =====================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=yq_history
TOPIC_COLLECTION=topic_evolution

# =====================================================
# Agent 行为
# =====================================================
AGENT_MCP_ENABLED=false
AGENT_MAX_ITERATIONS=6
AGENT_MEMORY_TTL_DAYS=90
AGENT_TOKEN_BUDGET=1500
AGENT_REFLECTION_ENABLED=true
AGENT_SELF_HEALING_ENABLED=true

# =====================================================
# 路径 / 端口
# =====================================================
# STATE_DB_PATH 默认 backend/data/radar_state.db（容器内）
# CRAWLER_DB_PATH 默认 backend/data/sqlite_tables.db
